// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  testResults TestResult[]
}

model TestResult {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
}

model Item {
  id            Int    @id @default(autoincrement())
  question      String
  options       String // Зберігаємо як рядок JSON (наприклад, '["1991", "1996"]')
  correctAnswer String
}